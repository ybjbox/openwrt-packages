#!/bin/sh

# 纯 POSIX Shell 物理常驻切入脚本 (纯 UNIX LF 格式 + 永久常驻同步至 /etc/config/user_info)

DHCP_JS="/www/luci-static/resources/view/network/dhcp.js"
STATUS_JS="/www/luci-static/resources/view/status/include/40_dhcp.js"
BANDIX_INDEX="/www/luci-static/resources/view/bandix/index.js"

# 1. DHCP 页面切入
if [ -f "$DHCP_JS" ]; then
    sed -i 's/function validateHostname(sid,s){/function validateHostname(sid,s){return true;/g' "$DHCP_JS"
    sed -i 's/duids\[duid_iaid\]\.ip6addrs\[0\]/(duids[duid_iaid].ip6addrs \&\& duids[duid_iaid].ip6addrs.length ? duids[duid_iaid].ip6addrs[0] : null)/g' "$DHCP_JS"
    
    if ! grep -q "co=ss.option(form.Value,'comment'" "$DHCP_JS"; then
        sed -i "s/so=ss.option(form.Value,'leasetime'/var co=ss.option(form.Value,'comment',_('Comment'));co.rmempty=true;so=ss.option(form.Value,'leasetime'/g" "$DHCP_JS"
    fi

    if ! grep -q "mac_comments" "$DHCP_JS"; then
        sed -i 's/return callDHCPLeases().then(function(leaseinfo){/return Promise.all([callDHCPLeases(),L.resolveDefault(uci.load("dhcp"))]).then(function(res){const leaseinfo=res[0]||{};const mac_comments={};uci.sections("dhcp","host").forEach(function(s){L.toArray(s.mac).forEach(function(m){if(s.comment)mac_comments[m.toLowerCase()]=s.comment;});});/g' "$DHCP_JS"
        sed -i "s~'%h'.format(host||'-')~'%s'.format((function(){var c=lease.macaddr?mac_comments[lease.macaddr.toLowerCase()]:null;return c?c:(host||'-');})())~g" "$DHCP_JS"
    fi
fi

# 2. 状态-概览切入
if [ -f "$STATUS_JS" ]; then
    if ! grep -q "mac_comments" "$STATUS_JS"; then
        sed -i 's/const machints=host_hints.getMACHints(false);/const machints=host_hints.getMACHints(false);const mac_comments={};uci.sections("dhcp","host").forEach(function(s){L.toArray(s.mac).forEach(function(m){if(s.comment)mac_comments[m.toLowerCase()]=s.comment;});});/g' "$STATUS_JS"
        sed -i "s~'%h'.format(host||'-')~'%s'.format((function(){var c=lease.macaddr?mac_comments[lease.macaddr.toLowerCase()]:null;return c?c:(host||'-');})())~g" "$STATUS_JS"
    fi
fi

# 3. Bandix 设备列表切入 (补全 uci.load('dhcp') 预编译加载)
if [ -f "$BANDIX_INDEX" ]; then
    if ! grep -q "uci.load('dhcp')" "$BANDIX_INDEX"; then
        sed -i "s/return Promise.all(\[/return Promise.all(\[uci.load('dhcp'),/g" "$BANDIX_INDEX"
    fi
    if ! grep -q "mac_comments" "$BANDIX_INDEX"; then
        sed -i 's/var filteredDevices=/if(stats\&\&Array.isArray(stats.d)){try{var mac_comments={};uci.sections("dhcp","host").forEach(function(s){L.toArray(s.mac).forEach(function(m){if(s.comment)mac_comments[m.toLowerCase()]=s.comment;});});stats.d.forEach(function(device){if(device\&\&device.mac){var cmt=mac_comments[device.mac.toLowerCase()];if(cmt){var curHost=(device.host||"").trim().replace(\/\\.lan$\/i,"");if(curHost!==""\&\&typeof device.sys_host!=="undefined"\&\&curHost!==device.sys_host\&\&curHost.indexOf(cmt)===-1){device.host=curHost;}else{device.host=cmt;}}}});}catch(e){}}var filteredDevices=/g' "$BANDIX_INDEX"
    fi
fi

# 4. 执行全自动镜像同步
[ -x /usr/bin/sync_dhcp_user_info ] && /usr/bin/sync_dhcp_user_info 2>/dev/null || true

rm -rf /tmp/luci-modulecache/* /tmp/luci-indexcache 2>/dev/null || true
exit 0
