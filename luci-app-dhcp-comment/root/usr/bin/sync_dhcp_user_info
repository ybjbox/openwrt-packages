#!/bin/sh

# 1. 物理重筑 user_info，确保 @user_info[%d] 下标完美连续
rm -f /etc/config/user_info
touch /etc/config/user_info

# 2. 顺序追加，避免 Subshell 内存遗失
for s in $(uci show dhcp | grep "=host" | cut -d. -f2 | cut -d= -f1); do
    mac=$(uci -q get "dhcp.$s.mac")
    comment=$(uci -q get "dhcp.$s.comment")
    if [ -n "$mac" ] && [ -n "$comment" ]; then
        for m in $mac; do
            lmac=$(echo "$m" | tr 'A-Z' 'a-z')
            uci add user_info user_info >/dev/null
            uci set user_info.@user_info[-1].mac="$lmac"
            uci set user_info.@user_info[-1].nickname="$comment"
        done
    fi
done

uci commit user_info 2>/dev/null || true
/etc/init.d/appfilter restart >/dev/null 2>&1 || true
